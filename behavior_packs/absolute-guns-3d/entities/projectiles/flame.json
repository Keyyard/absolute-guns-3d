          "remove_on_hit": {},
          "stick_in_ground": {
            "shake_time": 0
          }
        },
        "power": 1.5,
        "gravity": 0.01,
        "inertia": 1,
        "uncertaintyBase": 5.0,
        "uncertaintyMultiplier": 0,
        "anchor": 1,
        "offset": [0, 0, 0],
        "reflectOnHurt": false,
        "catch_fire": true
      },
      "minecraft:physics": {}
