{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "absolute_guns:tactical_knife_scope",
      "materials": {
        "default": "entity_emissive_alpha",
        "enchanted": "entity_alphatest_glint",
"ghost": "entity_alphablend"
      },
      "textures": {
        "default": "textures/3d/absolute_guns/tactical_knife_scope",
        "sword0": "textures/3d/absolute_guns/tactical_knife_scope",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "first_0": "geometry.tactical_knife_scope_first",
        "scope_0": "geometry.awm_scope",
        "third_0": "geometry.tactical_knife_scope_third"
      },
      "animations": {
        "wield_3d": "animation.absolute_guns_.wield_tactical_knife_scope",
        "scope_3d": "animation.absolute_guns_.scope_tactical_knife"
	},
      "scripts": {
        "animate": [
					{
						"wield_3d": "!query.is_sneaking"
					},
					{
						"scope_3d": "query.is_sneaking"
					}
        ]
      },
      "render_controllers": [
          {"controller.render.first_awm_0": "c.is_first_person && !q.is_sneaking"},
          {"controller.render.scope_awm_0": "c.is_first_person && q.is_sneaking"},
          {"controller.render.third_awm_0": "!c.is_first_person && q.is_sneaking"},
          {"controller.render.third_awm_0": "!c.is_first_person && !q.is_sneaking"}
      ]
    }
  }
}
