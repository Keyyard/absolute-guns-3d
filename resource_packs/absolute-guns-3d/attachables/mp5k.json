{
    "format_version": "1.10.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "absolute_guns:mp5k",
            "materials": {
                "default": "entity_alphatest",
"invisible": "entity_alphablend"
            },
            "textures": {
                "default": "textures/3d/absolute_guns/mp5"
            },
            "geometry": {
                "default": "geometry.mp5k"
            },
            "render_controllers": [
                "controller.render.spider"
            ],
            "animations": {
                "first_person_hold": "animation.absolute_guns.mp5.first_person_hold",
                "third_person_hold": "animation.absolute_guns.mp5.third_person_hold",
"draw": "animation.absolute_guns.mp5.draw",
                "first_person_controller": "controller.animation.absolute_guns_mp5k"
            },
            "scripts": {
                "animate": [
                    {
                        "first_person_controller": "c.is_first_person && query.get_equipped_item_name('main_hand') == 'mp5k'"
                    },
                    {
                        "third_person_hold": "!c.is_first_person"
                    }
                ]
            }
        }
    }
}