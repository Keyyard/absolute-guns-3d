{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.absolute_guns.glock.ctrl": {
			"initial_state": "draw",
			"states": {
				"draw": {
					"blend_transition": 0.1,
					"blend_via_shortest_path": true,
					"animations": [
						{
							"draw": "q.get_equipped_item_name(0) == 'glock' && !c.is_first_person"
						}
					],
					"transitions": [
						{
							"draw": "q.get_equipped_item_name(0) != 'glock'"
						},
						{
							"idle": "q.get_equipped_item_name(0) == 'glock' && q.any_animation_finished"
						}
					],
					"on_entry": [ "v.tick_delay = q.life_time;" ]
				},
				"idle": {
					"blend_transition": 0.2,
					"blend_via_shortest_path": true,
					"transitions": [
						{
							"draw": "q.get_equipped_item_name(0) != 'glock'"
						}
					],
					"on_entry": [ "v.tick_delay = q.life_time;" ]
				}
			}
		}
	}
}