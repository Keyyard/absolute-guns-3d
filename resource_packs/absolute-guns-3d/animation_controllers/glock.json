{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.absolute_guns.glock.ctrl": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": ["draw"],
                    "transitions": [
                        {
                            "using_item": "query.is_using_item == true"
                        }
                    ]
                },
                "using_item": {
                    "animations": [
                        "use_item"
                    ],
                    "transitions": [
                        {
                            "default": "q.all_animations_finished"
                        }
                    ]
                }
            }
        }
    }
}