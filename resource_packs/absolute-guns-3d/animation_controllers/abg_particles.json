{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.abg_particles": {
      "initial_state" : "default",
      "states": {
        "default": {
          "transitions": [
            { "bdc": "query.distance_from_camera > 0.1" }
          ]
        },
        "bdc": {
          "particle_effects": [
            {
              "effect": "tracer"
            }
          ],
          "transitions": [
            { "default": "query.is_alive" }
          ]
        }
      }
    }
  }
}