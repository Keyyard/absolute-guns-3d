{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.common.absolute_guns.attachable.use": {
      "initial_state": "default",
      "states": {
        "default": {
          "blend_transition": 0.1,
          "blend_via_shortest_path": true,
          "animations": ["use_item"],
          "transitions": [
            {
              "holding": "q.all_animations_finished"
            }
          ]
        },
        "holding": {
          "animations": ["first_person_hold"],
          "transitions": [
            {
              "default": "query.get_equipped_item_name('main_hand') != 'absolute_guns:spas'"
            }
          ]
        }
      }
    }
  }
}
