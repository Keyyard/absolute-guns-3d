{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.common.absolute_guns.attachable.use": {
            "initial_state": "default",
            "states": {
                "default": {
					"blend_transition": 0.1,
					"blend_via_shortest_path": true,
                    "animations": [
                        "use_item"
                    ],
					"transitions": [
						{
							"holding": "q.all_animations_finished"
						}
					],
					"on_entry": [ "v.tick_delay = q.life_time;" ]
				},
                "holding": {
                    "animations": ["first_person_hold"],
                    "transitions": [
                        {
                            "using_item": "query.is_using_item == true"
                        },
                        {
                            "default": "query.get_equipped_item_name('main_hand') != 'spas'"
                        }
                    ]
                },
                "using_item": {
                    "animations": [
                        "use_item"
                    ],
                    "transitions": [
                        {
                            "holding": "q.all_animations_finished"
                        },
                        {
                            "default": "query.get_equipped_item_name('main_hand') != 'spas'"
                        }
                    ]
                }
            }
        }
    }
}