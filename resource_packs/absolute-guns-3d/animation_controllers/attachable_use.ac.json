{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.absolute_guns": {
            "initial_state": "default",
            "states": {
                "default": {
                    "blend_transition": 0.1,
                    "animations": ["draw"],
                    "transitions": [
                        {
                            "hold": "query.all_animations_finished"
                        }
                    ]
                },
                "hold": {
                    "blend_transition": 0.1,
                    "animations": [
                        "first_person_hold"
                    ],
                    "transitions": [
                        {
                            "default": "query.all_animations_finished"
                        }
                    ]
                }
            }
        }
    }
}