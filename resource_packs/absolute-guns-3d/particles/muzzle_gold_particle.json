{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "absolute_guns:muzzle_gold_particle",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": "math.random(1,3)"
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"direction": ["math.random(-1,1)", 1, "math.random(-1,1)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "3 / Math.Random(1, 5) + 0.5"
			},
			"minecraft:particle_initial_speed": 5,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -10, 0],
				"linear_drag_coefficient": 2.5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_random_1 * variable.particle_random_2 * 0.4 + 0.1", "variable.particle_random_1 * variable.particle_random_2 * 0.4 + 0.1"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"flipbook": {
						"base_UV": [0, 96],
						"size_UV": [8, 8],
						"step_UV": [8, 0],
						"frames_per_second": 8,
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 1,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.31": "#1FE5B83F",
						"0.65": "#FFFFFFFF",
						"1.0": "#00E5B83F"
					}
				}
			}
		}
	}
